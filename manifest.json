{
  "name": "SAT Timer",
  "version": "1.0",
  "manifest_version": 3,
  "action": {
    "default_title": "SAT Practice Timer"
  },
  "permissions": ["activeTab", "scripting"],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [{
    "resources": ["content.css"],
    "matches": ["<all_urls>"]
  }]
}